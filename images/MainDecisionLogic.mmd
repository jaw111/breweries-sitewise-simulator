    R200_FILLING -->|Yes| R200_PUSH["Append roasted barley to Mash200.ConsList"]

    M200_RUNNING{"Mash200 State = Running?"}
    M200_RUNNING --> M200_TO_BOIL["Send ProductionID & Wort Item → Boil200\nIf draining: send Wort and lot"]

    BK200_RUNNING{"Boil200 State = Running?"}
    BK200_RUNNING --> BK200_TO_FER["Send BrewedWort metadata → Ferm200\nIf draining: send BrewedWort"]
